DECLARE @UserCode NVARCHAR(50) = '25033410';

;WITH UserHierarchy AS
(
    SELECT
        U.UserCode,
        U.RepManCode,
        U.RoleId,
        U.CompanyCode,
        0 AS HierarchyLevel
    FROM Users U
    WHERE U.UserCode = @UserCode

    UNION ALL

    SELECT
        U.UserCode,
        U.RepManCode,
        U.RoleId,
        U.CompanyCode,
        UH.HierarchyLevel + 1
    FROM Users U
    INNER JOIN UserHierarchy UH
        ON U.RepManCode = UH.UserCode
)
SELECT *
FROM UserHierarchy
ORDER BY HierarchyLevel, UserCode
OPTION (MAXRECURSION 100);


