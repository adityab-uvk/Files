DECLARE @UserCode NVARCHAR(50) = '25033410';

;WITH UserHierarchy AS
(
    SELECT U.UserCode
    FROM Users U
    WHERE U.UserCode = @UserCode

    UNION ALL

    SELECT U.UserCode
    FROM Users U
    INNER JOIN UserHierarchy UH
        ON U.RepManCode = UH.UserCode
),
AllowedCustomers AS
(
    SELECT DISTINCT CM.CustomerCode
    FROM TB_CustomerMaster CM
    WHERE CM.TM IN
    (
        SELECT UserCode
        FROM UserHierarchy
    )
)
SELECT
    O.CustomerCode,
    O.OrderNumber,
    DO.ProductId,
    DO.ProductName,
    DO.PriceCardType,
    DO.DispatchStatus,
    DO.TMApproval,
    DO.HAApproval,
    DO.PrimaryDispatchStatus,
    DO.SecondaryDispatchStatus
FROM OrdersMHZPC O
INNER JOIN DealerOrderMHZPC DO
    ON DO.OrderNumber = O.OrderNumber
WHERE O.CustomerCode IN
(
    SELECT CustomerCode
    FROM AllowedCustomers
)
AND DO.DispatchStatus = 'Pending'
AND
(
       (DO.TMApproval = 'Approved' AND DO.HAApproval = 'Pending')
    OR (DO.TMApproval = 'Pending' AND DO.HAApproval = 'Approved')
    OR (DO.TMApproval = 'Pending' AND DO.HAApproval = 'Pending')
)
ORDER BY O.CustomerCode, O.OrderNumber
OPTION (MAXRECURSION 100);


