    AC.CompanyCode,
    AC.TM,
    AC.CustomerCode,
    AC.CustomerName,
    O.OrderNumber,
    O.BillingAddress,
    O.ShippingAddress
FROM AllowedCustomers AC
LEFT JOIN OrdersMHZPC O
    ON O.CustomerCode = AC.CustomerCode
ORDER BY AC.CustomerCode, O.OrderNumber
OPTION (MAXRECURSION 100);


