DECLARE @ManagerUserCode NVARCHAR(50) = '25033410';

;WITH UserHierarchy AS
(
    -- Direct users under 25033410
    SELECT
        U.UserId,
        U.UserCode,
        U.CompanyCode,
        U.UserType,
        U.Name,
        U.FirstName,
        U.LastName,
        U.Email,
        U.ContactNumber,
        U.RepManCode,
        U.RoleId,
        U.Role_Details,
        U.JobTitle,
        U.Location,
        U.IsActive,
        1 AS HierarchyLevel
    FROM Users U
    WHERE U.RepManCode = @ManagerUserCode
      AND U.IsActive = 1

    UNION ALL

    -- Users reporting under previously found users
    SELECT
        U.UserId,
        U.UserCode,
        U.CompanyCode,
        U.UserType,
        U.Name,
        U.FirstName,
        U.LastName,
        U.Email,
        U.ContactNumber,
        U.RepManCode,
        U.RoleId,
        U.Role_Details,
        U.JobTitle,
        U.Location,
        U.IsActive,
        UH.HierarchyLevel + 1
    FROM Users U
    INNER JOIN UserHierarchy UH
        ON U.RepManCode = UH.UserCode
        AND U.CompanyCode = UH.CompanyCode
    WHERE U.IsActive = 1
)
SELECT
    UserId,
    UserCode,
    CompanyCode,
    Name,
    FirstName,
    LastName,
    Email,
    ContactNumber,
    RepManCode,
    RoleId,
    Role_Details,
    JobTitle,
    Location,
    IsActive,
    HierarchyLevel
FROM UserHierarchy
ORDER BY CompanyCode, HierarchyLevel, UserCode
OPTION (MAXRECURSION 100);
