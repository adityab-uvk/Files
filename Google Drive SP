DECLARE @Status BIT = NULL;
DECLARE @PriceCardType NVARCHAR(10) = NULL;
DECLARE @Variety NVARCHAR(100) = NULL;
DECLARE @CustomerCode NVARCHAR(50) = NULL;

SELECT *
FROM dbo.TB_PriceCard pc
WHERE
    (@Status IS NULL OR pc.Status = @Status)
    AND
    (
        @PriceCardType IS NULL
        OR pc.PriceCardType = @PriceCardType
    )
    AND
    (
        @Variety IS NULL
        OR pc.Variety = @Variety
    )
    AND
    (
        @CustomerCode IS NULL
    );
