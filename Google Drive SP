DECLARE @UserCode NVARCHAR(50) = '25033410';

SELECT
    UserId,
    UserCode,
    CompanyCode,
    RoleId,
    RepManCode,
    IsActive,
    Name
FROM Users
WHERE UserCode = @UserCode;

